---
import { siteData } from "../data/siteData";

const { values } = siteData;
---

<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">{values.title}</h2>
      <p class="section__subtitle">{values.description}</p>
    </div>
    <div class="values-grid">
      {values.items.map((item, index) => (
        <div class="value-item">
          <div class="value-item__number">{index + 1}</div>
          <h3 class="value-item__title">{item.title}</h3>
          <p class="value-item__description">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
