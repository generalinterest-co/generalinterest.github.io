---
import { siteData } from "../data/siteData";

const { teamShowcase } = siteData;
---

<section class="section section--alt">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">{teamShowcase.title}</h2>
      <p class="section__subtitle">{teamShowcase.subtitle}</p>
    </div>
    <div class="team-grid">
      {teamShowcase.members.map((member) => (
        <div class="team-card">
          <img
            class="team-card__image"
            src={member.image}
            alt={member.name}
            loading="lazy"
          />
          <h3 class="team-card__name">{member.name}</h3>
          <div class="team-card__role">{member.role}</div>
          <p class="team-card__bio">{member.bio}</p>
        </div>
      ))}
    </div>
  </div>
</section>
